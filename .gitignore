# Python 基础
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 虚拟环境 (匹配 .venv, .venv310, venv 等)
.venv*
venv/
env/

# 编辑器与系统
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- 重点：科研数据与模型权重 ---

# 忽略整个 data 文件夹（包括 raw.zip 和所有子目录）
# 仅保留版本化 split 配置；原始数据与处理中间产物仍全部忽略。
data/
!data/
data/*
!data/splits/
data/splits/*
!data/splits/split_unseen_fixed_test_obj004_obj007_v1.yaml
!configs/data/
!configs/data/*.yaml
*.zip
*.tar.gz
*.7z

# 忽略所有运行日志和模型权重
runs/
evals/
outputs/
.codex_tmp/
*.pt
*.pth
*.ckpt
lightning_logs/

# 日志
*.log
